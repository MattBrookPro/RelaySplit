# RelaySplit control server configuration.
# The REAL values live in /root/apps/relaysplit/.env on the VPS and are NEVER committed.
# (This server reads that file directly; see src/config.ts.)

SIGNAL_PORT=8080
TURN_SECRET=replace-with-the-coturn-static-auth-secret
TURN_REALM=relaysplit.vaguelystrange.com
TURN_HOST=relaysplit.vaguelystrange.com
